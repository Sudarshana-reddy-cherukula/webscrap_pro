# Copy this file to .env and update values
# NEVER commit .env to version control

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=Cluster0

# JWT Configuration
JWT_SECRET=your-secure-random-string-here
JWT_EXPIRE=7d

# Socket.io Configuration
SOCKET_PORT=5001

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./src/uploads

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./src/logs/app.log

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this

# Export Configuration
EXPORT_PATH=./src/exports
EXPORT_CLEANUP_HOURS=24

# Python Service URLs
PDF_SERVICE_URL=http://localhost:8002
SCRAPING_SERVICE_URL=http://localhost:8001

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback
BACKEND_URL=http://localhost:5000

# n8n Email Automation (optional — emails handled by n8n when configured)
N8N_WEBHOOK_URL=http://localhost:5678/webhook/email

# Email / SMTP (optional — emails logged when not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=WebScrap Pro <no-reply@webscrappro.io>

# OpenAI / AI Features (optional — AI features disabled when not configured)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Redis (optional — enables queue, caching, per-user rate limits)
REDIS_URL=redis://localhost:6379

# S3 Storage (optional — falls back to local disk)
S3_BUCKET=your-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# Sentry (optional — error tracking)
SENTRY_DSN=https://your-sentry-dsn
VITE_SENTRY_DSN=https://your-frontend-sentry-dsn
