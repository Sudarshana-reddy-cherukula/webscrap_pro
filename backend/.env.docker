# WebScrap Pro - Render Environment Variables
# Copy these into Render Dashboard → Environment tab
# or import this .env file directly

# ===== REQUIRED =====
MONGO_URI=mongodb+srv://web_scrap_1:hqj4mkg7MBxKGcza@cluster0.d0njh1f.mongodb.net/?appName=Cluster0
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_PLUS_CHARACTER_STRING

# ===== SERVER =====
NODE_ENV=production
PORT=5000
LOG_LEVEL=info

# ===== URLS =====
FRONTEND_URL=http://localhost:5173/
BACKEND_URL=http://localhost:5000/

# ===== REDIS (Upstash or Docker) =====
REDIS_URL=redis://default:YOUR_UPSTASH_PASSWORD@YOUR_UPSTASH_HOST:6379

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ===== EMAIL (n8n with Gmail OAuth) =====
N8N_WEBHOOK_URL=http://localhost:5678/webhook/email
EMAIL_FROM=WebScrap Pro <your-email@gmail.com>

# ===== SMTP (fallback when n8n unavailable) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ===== OPENAI (AI features) =====
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ===== GOOGLE OAUTH (optional) =====
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://webscrap-pro-backend.onrender.com/api/auth/google/callback

# ===== S3 STORAGE (optional) =====
S3_BUCKET=your-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key

# ===== SENTRY (optional) =====
SENTRY_DSN=https://your-sentry-dsn
